  $t1 : MetricTick( machineId == "PKG", metricKey == "CASES_PER_MIN", tickIndex == $i11 - 10, value < $v2, $v1 : value )
  not Anomaly( machineId == "PKG", type == AnomalyType.RISING_TREND, metricKey == "CASES_PER_MIN" )
