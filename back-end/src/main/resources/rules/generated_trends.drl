end

rule "Auto packer — Throughput rising over 10 steps"
salience 15
when
  SimulatedClock( $t : now )
  $maxTick : Number() from accumulate(
    MetricTick( machineId == "PKG", metricKey == "CASES_PER_MIN", $ti : tickIndex ),
    max( $ti )
  )
  $t11 : MetricTick( machineId == "PKG", metricKey == "CASES_PER_MIN", $i11 : tickIndex == $maxTick.longValue(), $v11 : value )
  $t10 : MetricTick( machineId == "PKG", metricKey == "CASES_PER_MIN", tickIndex == $i11 - 1, value < $v11, $v10 : value )
  $t9 : MetricTick( machineId == "PKG", metricKey == "CASES_PER_MIN", tickIndex == $i11 - 2, value < $v10, $v9 : value )
