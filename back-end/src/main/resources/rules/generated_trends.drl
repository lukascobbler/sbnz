  $c6 : MetricTick( machineId == "CNC", metricKey == "SPINDLE_LOAD_PCT", $i6 : tickIndex == $maxTick.longValue(), $w6 : value )
  $c5 : MetricTick( machineId == "CNC", metricKey == "SPINDLE_LOAD_PCT", tickIndex == $i6 - 1, value > $w6, $w5 : value )
