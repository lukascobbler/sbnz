  $t7 : MetricTick( machineId == "PKG", metricKey == "CASES_PER_MIN", tickIndex == $i11 - 4, value < $v8, $v7 : value )
  $t6 : MetricTick( machineId == "PKG", metricKey == "CASES_PER_MIN", tickIndex == $i11 - 5, value < $v7, $v6 : value )
  $t5 : MetricTick( machineId == "PKG", metricKey == "CASES_PER_MIN", tickIndex == $i11 - 6, value < $v6, $v5 : value )
  $t4 : MetricTick( machineId == "PKG", metricKey == "CASES_PER_MIN", tickIndex == $i11 - 7, value < $v5, $v4 : value )
  $t3 : MetricTick( machineId == "PKG", metricKey == "CASES_PER_MIN", tickIndex == $i11 - 8, value < $v4, $v3 : value )
