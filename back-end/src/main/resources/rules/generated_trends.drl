  $c2 : MetricTick( machineId == "CNC", metricKey == "SPINDLE_LOAD_PCT", tickIndex == $i6 - 4, value > $w3, $w2 : value )
  $c1 : MetricTick( machineId == "CNC", metricKey == "SPINDLE_LOAD_PCT", tickIndex == $i6 - 5, value > $w2, $w1 : value )
then
