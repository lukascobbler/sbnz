package rules;

import com.luka.kbpdm.domain.machine.Machine;
import com.luka.kbpdm.domain.diagnosis.Intervention;
import com.luka.kbpdm.domain.diagnosis.PriorityLevel;
import com.luka.kbpdm.domain.safety.SafetyCheck;
import com.luka.kbpdm.domain.safety.SafetyResult;
import com.luka.kbpdm.domain.safety.MachineOverworked;
import com.luka.kbpdm.domain.telemetry.SimulatedClock;
import com.luka.kbpdm.domain.telemetry.TickStatus;
import com.luka.kbpdm.domain.telemetry.MetricTick;
import com.luka.kbpdm.domain.telemetry.CurrentMetric;

dialect "java"

declare TelemetryReading
  @role( event )
  @timestamp( ts )
end

declare TickStatus
  @role( event )
  @timestamp( ts )
end

rule "Pushed conveyor line (belt speed, vibration, reject rate)"
salience 35
when
  SimulatedClock( $t : now )
  CurrentMetric( machineId == "LIN", metricKey == "BELT_SPEED_PCT", value >= 99.0 )
  CurrentMetric( machineId == "LIN", metricKey == "VIBRATION_RMS", value >= 3.5 )
  CurrentMetric( machineId == "PKG", metricKey == "REJECT_PCT", value >= 2.5 )
  not Intervention( sourceRule == "X_PUSHED_LINE" )
then
  insert(new Intervention(
      "LIN",
      PriorityLevel.MEDIUM,
      "X_PUSHED_LINE",
      "Line is being pushed (high belt speed + high rejection rate) while conveyor vibration is elevated: reduce line speed and inspect bearings/alignment.",
      $t
  ));
end

rule "CNC high spindle load and line speed causing high seal temperature (spindle load, line belt speed, seal temperature)"
salience 34
when
  SimulatedClock( $t : now )
  CurrentMetric( machineId == "CNC", metricKey == "SPINDLE_LOAD_PCT", value >= 80 )
  CurrentMetric( machineId == "LIN", metricKey == "BELT_SPEED_PCT", value >= 98.0 )
  CurrentMetric( machineId == "PKG", metricKey == "SEAL_TEMP_C", value >= 93.0 )
  not Intervention( sourceRule == "X_LIN_TOO_FAST" )
then
  insert(new Intervention(
      "LIN",
      PriorityLevel.HIGH,
      "X_LIN_TOO_FAST",
      "CNC spindle load and LIN belt speed is causing too high seal temperature: inspect LIN machine.",
      $t
  ));
end

rule "Clear pushed-line intervention"
salience 5
when
  SimulatedClock( $t : now )
  $i : Intervention( sourceRule == "X_PUSHED_LINE", decidedAt != null, decidedAt < $t )
  not(
    CurrentMetric( machineId == "LIN", metricKey == "BELT_SPEED_PCT", value >= 99.0 )
    and CurrentMetric( machineId == "LIN", metricKey == "VIBRATION_RMS", value >= 3.5 )
    and CurrentMetric( machineId == "PKG", metricKey == "REJECT_PCT", value >= 2.5 )
  )
then
  delete($i);
end

rule "Clear CNC spindle load and belt speed causing high seal temperature intervention"
salience 5
when
  SimulatedClock( $t : now )
  $i : Intervention( sourceRule == "X_LIN_TOO_FAST", decidedAt != null, decidedAt < $t )
  not(
      CurrentMetric( machineId == "CNC", metricKey == "SPINDLE_LOAD_PCT", value >= 80 )
      and CurrentMetric( machineId == "LIN", metricKey == "BELT_SPEED_PCT", value >= 98.0 )
      and CurrentMetric( machineId == "PKG", metricKey == "SEAL_TEMP_C", value >= 93.0 )
  )
then
  delete($i);
end

rule "Stop machine after repeated stress on critical sensors"
salience 12
when
  SimulatedClock( $t : now )
  $m : Machine( $id : machineId )
  $t1 : TickStatus( machineId == $id, sustainedStressPresent == true ) over window:time(100h)
  $t2 : TickStatus( machineId == $id, sustainedStressPresent == true, this after[1m, 1000m] $t1 )
  $t3 : TickStatus( machineId == $id, sustainedStressPresent == true, this after[1m, 1000m] $t2 )
  $t4 : TickStatus( machineId == $id, sustainedStressPresent == true, this after[1m, 1000m] $t3 )
  $t5 : TickStatus( machineId == $id, sustainedStressPresent == true, this after[1m, 4800m] $t1, this after[1m, 1000m] $t4 )
  not MachineOverworked( machineId == $id )
  not Intervention( machineId == $id, priority == PriorityLevel.CRITICAL )
then
  insert(new MachineOverworked(
      $id,
      "Use Fix to acknowledge and reset."
  ));
  insert(new Intervention(
      $id,
      PriorityLevel.CRITICAL,
      "The machine stopped after critical sensors stayed in a stressed range for five checks in a row. Inspect the equipment before resuming work.",
      $t
  ));
end

rule "Safety evaluation: not safe"
salience 3
when
  $check : SafetyCheck( $id : machineId )
  $reason : MachineOverworked( machineId == $id )
  not SafetyResult( machineId == $id )
then
  insert(new SafetyResult($id, "MACHINE_OVERWORKED: " + $reason.getDetails(), false, $check.getCheckedAt()));
end

rule "Safety evaluation: safe"
salience 2
when
  $check : SafetyCheck( $id : machineId )
  not MachineOverworked( machineId == $id )
  not SafetyResult( machineId == $id )
then
  insert(new SafetyResult($id, "No safety issues detected.", true, $check.getCheckedAt()));
end