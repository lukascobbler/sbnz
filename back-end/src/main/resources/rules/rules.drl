package rules;

import com.luka.kbpdm.domain.Machine;
import com.luka.kbpdm.domain.Intervention;
import com.luka.kbpdm.domain.PriorityLevel;
import com.luka.kbpdm.domain.ComponentStatus;
import com.luka.kbpdm.domain.HealthStatus;
import com.luka.kbpdm.domain.SafetyCheck;
import com.luka.kbpdm.domain.SafetyResult;
import com.luka.kbpdm.domain.UnsafeReason;
import com.luka.kbpdm.domain.SimulatedClock;
import com.luka.kbpdm.domain.MachineHalted;
import com.luka.kbpdm.domain.TickStatus;
import com.luka.kbpdm.domain.MetricTick;
import com.luka.kbpdm.domain.CurrentMetric;

dialect "java"

declare TelemetryReading
  @role( event )
  @timestamp( ts )
end

declare TickStatus
  @role( event )
  @timestamp( ts )
end

declare MetricTick
  @role( event )
  @timestamp( ts )
end

rule "Cross-machine: Pushed line (high belt speed + LIN vibration + high pack throughput)"
salience 35
when
  SimulatedClock( $t : now )
  CurrentMetric( machineId == "LIN", metricKey == "BELT_SPEED_PCT", value >= 99.0 )
  CurrentMetric( machineId == "LIN", metricKey == "VIBRATION_RMS", value >= 3.5 )
  CurrentMetric( machineId == "PKG", metricKey == "CASES_PER_MIN", value >= 125.0 )
  not Intervention( sourceRule == "X_PUSHED_LINE" )
then
  insert(new Intervention(
      "LIN",
      PriorityLevel.HIGH,
      "X_PUSHED_LINE",
      "Line is being pushed (high belt speed + high pack throughput) while conveyor vibration is elevated: reduce line speed and inspect bearings/alignment.",
      $t
  ));
end

rule "Cross-machine: LIN instability under speed (vibration warning + rising rejects)"
salience 34
when
  SimulatedClock( $t : now )
  CurrentMetric( machineId == "LIN", metricKey == "BELT_SPEED_PCT", value >= 99.0 )
  CurrentMetric( machineId == "LIN", metricKey == "VIBRATION_RMS", value >= 3.5 )
  CurrentMetric( machineId == "PKG", metricKey == "REJECT_PCT", value >= 2 )
  not Intervention( sourceRule == "X_LIN_INSTABILITY" )
then
  insert(new Intervention(
      "LIN",
      PriorityLevel.MEDIUM,
      "X_LIN_INSTABILITY",
      "Conveyor vibration is trending high at elevated belt speed while downstream rejects increase: inspect belt tracking, tension, and bearing condition.",
      $t
  ));
end

rule "Clear intervention: pushed line resolved"
salience 5
when
  SimulatedClock( $t : now )
  $i : Intervention( sourceRule == "X_PUSHED_LINE", decidedAt != null, decidedAt < $t )
  not(
    CurrentMetric( machineId == "LIN", metricKey == "BELT_SPEED_PCT", value >= 99.0 )
    and CurrentMetric( machineId == "LIN", metricKey == "VIBRATION_RMS", value >= 3.5 )
    and CurrentMetric( machineId == "PKG", metricKey == "CASES_PER_MIN", value >= 125.0 )
  )
then
  delete($i);
end

rule "Clear intervention: LIN instability resolved"
salience 5
when
  SimulatedClock( $t : now )
  $i : Intervention( sourceRule == "X_LIN_INSTABILITY", decidedAt != null, decidedAt < $t )
  not(
    CurrentMetric( machineId == "LIN", metricKey == "BELT_SPEED_PCT", value >= 99.0 )
    and CurrentMetric( machineId == "LIN", metricKey == "VIBRATION_RMS", value >= 3.5 )
    and CurrentMetric( machineId == "PKG", metricKey == "REJECT_PCT", value >= 2 )
  )
then
  delete($i);
end

rule "Halt: 5 consecutive ticks in critical metric stress band (OR)"
salience 12
when
  SimulatedClock( $t : now )
  $m : Machine( $id : machineId )
  $t1 : TickStatus( machineId == $id, sustainedStressPresent == true ) over window:time(100h)
  $t2 : TickStatus( machineId == $id, sustainedStressPresent == true, this after[1m, 1000m] $t1 )
  $t3 : TickStatus( machineId == $id, sustainedStressPresent == true, this after[1m, 1000m] $t2 )
  $t4 : TickStatus( machineId == $id, sustainedStressPresent == true, this after[1m, 1000m] $t3 )
  $t5 : TickStatus( machineId == $id, sustainedStressPresent == true, this after[1m, 4800m] $t1, this after[1m, 1000m] $t4 )
  not MachineHalted( machineId == $id )
  not Intervention( machineId == $id, priority == PriorityLevel.CRITICAL )
  $cs : ComponentStatus( machineId == $id, health != HealthStatus.FAIL )
then
  insert(new MachineHalted($id));
  modify($cs) { setHealth(HealthStatus.FAIL) };
  insert(new Intervention(
      $id,
      PriorityLevel.CRITICAL,
      "Halt: one or more critical metrics remained in stress band for 5 consecutive sub-steps (OR). Inspect machine.",
      $t
  ));
end

rule "Safety: halted machine is unsafe"
salience 6
when
  $h : MachineHalted( $id : machineId )
  not UnsafeReason( machineId == $id, code == "OPERATOR_HALT" )
then
  insert(new UnsafeReason(
      $id,
      "OPERATOR_HALT",
      "Sustained stress band (at least one critical metric) for 5 consecutive ticks; operator fix required."
  ));
end

rule "Safety: unsafe result"
salience 3
when
  $check : SafetyCheck( $id : machineId )
  $reason : UnsafeReason( machineId == $id )
  not SafetyResult( machineId == $id )
then
  insert(new SafetyResult($id, false, $reason.getCode() + ":" + $reason.getDetails(), $check.getCheckedAt()));
end

rule "Safety: safe result"
salience 2
when
  $check : SafetyCheck( $id : machineId )
  not UnsafeReason( machineId == $id )
  not SafetyResult( machineId == $id )
then
  insert(new SafetyResult($id, true, "No safety issues detected.", $check.getCheckedAt()));
end
