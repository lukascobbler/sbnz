package rules;
import com.luka.kbpdm.domain.machine.Machine;
import com.luka.kbpdm.domain.telemetry.TelemetryReading;
import com.luka.kbpdm.domain.diagnosis.Anomaly;
import com.luka.kbpdm.domain.diagnosis.AnomalyType;
import com.luka.kbpdm.domain.telemetry.SimulatedClock;
dialect "java"

rule "Plant climate — Ambient temperature above high band"
salience 50
when
  SimulatedClock( $t : now )
  $m : Machine( machineId == "CLM" )
  $r : TelemetryReading( machineId == $m.machineId, metric == "AMBIENT_C", value >= 29.0 )
  not Anomaly( machineId == $m.machineId, type == AnomalyType.ABOVE_THRESHOLD, metricKey == "AMBIENT_C" )
then
  insert(new Anomaly(
      $m.getMachineId(),
      AnomalyType.ABOVE_THRESHOLD,
      "AMBIENT_C",
      "Ambient temperature reached or exceeded the configured high limit for this equipment.",
      $t
  ));
end

