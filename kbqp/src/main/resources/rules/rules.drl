package rules;

import com.luka.kbpdm.domain.Machine;
import com.luka.kbpdm.domain.Condition;
import com.luka.kbpdm.domain.ConditionType;
import com.luka.kbpdm.domain.Anomaly;
import com.luka.kbpdm.domain.AnomalyType;
import com.luka.kbpdm.domain.Intervention;
import com.luka.kbpdm.domain.PriorityLevel;
import com.luka.kbpdm.domain.TelemetryReading;
import com.luka.kbpdm.domain.TelemetryMetric;
import com.luka.kbpdm.domain.ComponentStatus;
import com.luka.kbpdm.domain.HealthStatus;
import com.luka.kbpdm.domain.SafetyCheck;
import com.luka.kbpdm.domain.SafetyResult;
import com.luka.kbpdm.domain.UnsafeReason;
import com.luka.kbpdm.domain.SimulatedClock;
import com.luka.kbpdm.domain.MachineHalted;
import com.luka.kbpdm.domain.TickStatus;

dialect "java"

declare TelemetryReading
  @role( event )
  @timestamp( ts )
end

declare TickStatus
  @role( event )
  @timestamp( ts )
end

rule "L2: Potential bearing failure anomaly"
salience 20
when
  SimulatedClock( $t : now )
  $m : Machine( $id : machineId )
  Condition( machineId == $id, type == ConditionType.HIGH_TEMPERATURE )
  Condition( machineId == $id, type == ConditionType.HIGH_VIBRATION )
  not Anomaly( machineId == $id, type == AnomalyType.POTENTIAL_BEARING_FAILURE )
then
  insert(new Anomaly(
      $id,
      AnomalyType.POTENTIAL_BEARING_FAILURE,
      "High temperature and high vibration detected.",
      $t
  ));
end

