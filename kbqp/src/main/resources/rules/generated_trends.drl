package rules;
import com.luka.kbpdm.domain.Anomaly;
import com.luka.kbpdm.domain.AnomalyType;
import com.luka.kbpdm.domain.MetricTick;
import com.luka.kbpdm.domain.SimulatedClock;
import java.lang.Number;
dialect "java"

rule "CEP: LIN TEMPERATURE_C rising trend"
salience 15
when
  SimulatedClock( $t : now )
  $maxTick : Number() from accumulate(
    MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", $ti : tickIndex ),
    max( $ti )
  )
  $t11 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", $i11 : tickIndex == $maxTick.longValue(), $v11 : value )
  $t10 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i11 - 1, value < $v11, $v10 : value )
  $t9 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i11 - 2, value < $v10, $v9 : value )
  $t8 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i11 - 3, value < $v9, $v8 : value )
  $t7 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i11 - 4, value < $v8, $v7 : value )
  $t6 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i11 - 5, value < $v7, $v6 : value )
  $t5 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i11 - 6, value < $v6, $v5 : value )
  $t4 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i11 - 7, value < $v5, $v4 : value )
  $t3 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i11 - 8, value < $v4, $v3 : value )
  $t2 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i11 - 9, value < $v3, $v2 : value )
  $t1 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i11 - 10, value < $v2, $v1 : value )
  not Anomaly( machineId == "LIN", type == AnomalyType.RISING_TREND, metricKey == "TEMPERATURE_C" )
then
  insert(new Anomaly(
      "LIN",
      AnomalyType.RISING_TREND,
      "TEMPERATURE_C",
      "Temperature (TEMPERATURE_C) rose 10 consecutive ticks (strictly increasing each sub-step).",
      $t
  ));
end
rule "CEP: LIN TEMPERATURE_C rising trend cleared"
salience 16
when
  $a : Anomaly( machineId == "LIN", type == AnomalyType.RISING_TREND, metricKey == "TEMPERATURE_C" )
  $maxTick : Number() from accumulate(
    MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", $ti : tickIndex ),
    max( $ti )
  )
  $c6 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", $i6 : tickIndex == $maxTick.longValue(), $w6 : value )
  $c5 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i6 - 1, value > $w6, $w5 : value )
  $c4 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i6 - 2, value > $w5, $w4 : value )
  $c3 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i6 - 3, value > $w4, $w3 : value )
  $c2 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i6 - 4, value > $w3, $w2 : value )
  $c1 : MetricTick( machineId == "LIN", metricKey == "TEMPERATURE_C", tickIndex == $i6 - 5, value > $w2, $w1 : value )
then
  delete( $a );
end

