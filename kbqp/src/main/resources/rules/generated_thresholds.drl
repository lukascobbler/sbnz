package rules;
import com.luka.kbpdm.domain.Machine;
import com.luka.kbpdm.domain.TelemetryReading;
import com.luka.kbpdm.domain.Anomaly;
import com.luka.kbpdm.domain.AnomalyType;
import com.luka.kbpdm.domain.SimulatedClock;
dialect "java"

rule "Threshold: CLM AMBIENT_C high"
salience 50
when
  SimulatedClock( $t : now )
  $m : Machine( machineId == "CLM" )
  $r : TelemetryReading( machineId == $m.machineId, metric == "AMBIENT_C", value >= 29.0 )
  not Anomaly( machineId == $m.machineId, type == AnomalyType.ABOVE_THRESHOLD, metricKey == "AMBIENT_C" )
then
  insert(new Anomaly(
      $m.getMachineId(),
      AnomalyType.ABOVE_THRESHOLD,
      "AMBIENT_C",
      "Ambient temperature reached or exceeded the configured high band for this machine.",
      $t
  ));
end

