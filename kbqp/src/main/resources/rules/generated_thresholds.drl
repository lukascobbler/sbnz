  not Anomaly( machineId == $m.machineId, type == AnomalyType.TEMPERATURE_ABOVE_THRESHOLD )
then
  insert(new Anomaly(
      $m.getMachineId(),
      AnomalyType.TEMPERATURE_ABOVE_THRESHOLD,
