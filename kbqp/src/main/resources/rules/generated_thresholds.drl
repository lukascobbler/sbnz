package rules;
import com.luka.kbpdm.domain.Machine;
import com.luka.kbpdm.domain.MachineType;
import com.luka.kbpdm.domain.TelemetryMetric;
import com.luka.kbpdm.domain.TelemetryReading;
import com.luka.kbpdm.domain.Condition;
import com.luka.kbpdm.domain.ConditionType;
dialect "java"

rule "Threshold: CNC high temperature"
salience 50
when
  $m : Machine( type == MachineType.CNC )
  $r : TelemetryReading( machineId == $m.machineId, metric == TelemetryMetric.TEMPERATURE_C, value >= 80.0 )
  not Condition( machineId == $m.machineId, type == ConditionType.HIGH_TEMPERATURE )
then
  insert(new Condition($m.getMachineId(), ConditionType.HIGH_TEMPERATURE, java.time.Instant.ofEpochMilli($r.getTs())));
end

rule "Threshold: CNC high vibration"
salience 50
when
  $m : Machine( type == MachineType.CNC )
  $r : TelemetryReading( machineId == $m.machineId, metric == TelemetryMetric.VIBRATION_RMS, value >= 5.0 )
  not Condition( machineId == $m.machineId, type == ConditionType.HIGH_VIBRATION )
then
  insert(new Condition($m.getMachineId(), ConditionType.HIGH_VIBRATION, java.time.Instant.ofEpochMilli($r.getTs())));
end

