salience 50
when
  $m : Machine( type == MachineType.CONVEYOR )
  $r : TelemetryReading( machineId == $m.machineId, metric == TelemetryMetric.TEMPERATURE_C, value >= 70.0 )
  not Condition( machineId == $m.machineId, type == ConditionType.HIGH_TEMPERATURE )
then
  insert(new Condition($m.getMachineId(), ConditionType.HIGH_TEMPERATURE, java.time.Instant.ofEpochMilli($r.getTs())));
end

rule "Threshold: Conveyor high vibration"
salience 50
when
  $m : Machine( type == MachineType.CONVEYOR )
  $r : TelemetryReading( machineId == $m.machineId, metric == TelemetryMetric.VIBRATION_RMS, value >= 4.0 )
  not Condition( machineId == $m.machineId, type == ConditionType.HIGH_VIBRATION )
then
  insert(new Condition($m.getMachineId(), ConditionType.HIGH_VIBRATION, java.time.Instant.ofEpochMilli($r.getTs())));
end

rule "Threshold: Press high temperature"
salience 50
when
  $m : Machine( type == MachineType.PRESS )
  $r : TelemetryReading( machineId == $m.machineId, metric == TelemetryMetric.TEMPERATURE_C, value >= 75.0 )
  not Condition( machineId == $m.machineId, type == ConditionType.HIGH_TEMPERATURE )
then
  insert(new Condition($m.getMachineId(), ConditionType.HIGH_TEMPERATURE, java.time.Instant.ofEpochMilli($r.getTs())));
