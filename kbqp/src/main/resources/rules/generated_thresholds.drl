rule "Threshold: Press high vibration"
salience 50
when
  $m : Machine( type == MachineType.PRESS )
  $r : TelemetryReading( machineId == $m.machineId, metric == TelemetryMetric.VIBRATION_RMS, value >= 4.5 )
  not Condition( machineId == $m.machineId, type == ConditionType.HIGH_VIBRATION )
then
  insert(new Condition($m.getMachineId(), ConditionType.HIGH_VIBRATION, java.time.Instant.ofEpochMilli($r.getTs())));
end


