package rules;
import com.luka.kbpdm.domain.Machine;
import com.luka.kbpdm.domain.TelemetryMetric;
import com.luka.kbpdm.domain.TelemetryReading;
import com.luka.kbpdm.domain.Anomaly;
import com.luka.kbpdm.domain.AnomalyType;
import com.luka.kbpdm.domain.SimulatedClock;
dialect "java"

rule "Threshold: LIN high temperature"
salience 50
when
  SimulatedClock( $t : now )
  $m : Machine( machineId == "LIN" )
  $r : TelemetryReading( machineId == $m.machineId, metric == TelemetryMetric.TEMPERATURE_C, value >= 86.0 )
  not Anomaly( machineId == $m.machineId, type == AnomalyType.TEMPERATURE_ABOVE_THRESHOLD )
then
  insert(new Anomaly(
      $m.getMachineId(),
      AnomalyType.TEMPERATURE_ABOVE_THRESHOLD,
      "Temperature reached or exceeded the configured high band for this machine.",
      $t
  ));
end

rule "Threshold: LIN high vibration"
salience 50
when
  SimulatedClock( $t : now )
  $m : Machine( machineId == "LIN" )
  $r : TelemetryReading( machineId == $m.machineId, metric == TelemetryMetric.VIBRATION_RMS, value >= 4.4 )
  not Anomaly( machineId == $m.machineId, type == AnomalyType.VIBRATION_ABOVE_THRESHOLD )
then
  insert(new Anomaly(
      $m.getMachineId(),
      AnomalyType.VIBRATION_ABOVE_THRESHOLD,
      "Vibration reached or exceeded the configured high band for this machine.",
      $t
  ));
end

